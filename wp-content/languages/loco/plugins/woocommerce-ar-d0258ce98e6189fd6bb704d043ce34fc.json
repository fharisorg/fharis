\u0644\u0645\u0639\u0627\u064a\u064a\u0631 \u0627\u0644\u0645\u062d\u062f\u062f\u0629 \u0648\u0627\u0633\u0645\u062d \u0644\u0644\u0645\u062a\u0633\u0648\u0642\u064a\u0646 \u0628\u0627\u0644\u062a\u0635\u0641\u064a\u0629."],"Showcase your featured products.":["\u0627\u0639\u0631\u0636 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u0628\u0627\u0631\u0632\u0629 \u0644\u062f\u064a\u0643."],"Specify a fixed width.":["\u062d\u062f\u062f \u0639\u0631\u0636\u064b\u0627 \u062b\u0627\u0628\u062a\u064b\u0627."],"Stack":["\u062a\u0643\u062f\u064a\u0633"],"Stock Status":["\u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u062e\u0632\u0648\u0646"],"Stretch to fill available space.":["\u0642\u0645 \u0628\u0627\u0644\u062a\u0645\u062f\u064a\u062f \u0644\u0645\u0644\u0621 \u0627\u0644\u0645\u0633\u0627\u0641\u0629 \u0627\u0644\u0645\u062a\u0648\u0641\u0631\u0629."],"Tags":["\u0627\u0644\u0648\u0633\u0648\u0645"],"The following error was returned":["\u062a\u0645 \u0625\u0631\u062c\u0627\u0639 \u0627\u0644\u062e\u0637\u0623 \u0627\u0644\u062a\u0627\u0644\u064a"],"The following error was returned from the API":["\u062a\u0645 \u0625\u0631\u062c\u0627\u0639 \u0627\u0644\u062e\u0637\u0623 \u0627\u0644\u062a\u0627\u0644\u064a \u0645\u0646 \u0648\u0627\u062c\u0647\u0629 \u0628\u0631\u0645\u062c\u0629 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0627\u062a"],"Top Rated Products":["\u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0623\u0639\u0644\u0649 \u062a\u0642\u064a\u064a\u0645\u064b\u0627"],"Top rated products":["\u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0623\u0639\u0644\u0649 \u062a\u0642\u064a\u064a\u0645\u0627\u064b"],"Upsells":["\u0645\u0646\u062a\u062c\u0627\u062a \u064a\u0648\u0635\u0649 \u0628\u0647\u0627"],"Upsells are typically products that are extra profitable or better quality or more expensive. Experiment with combinations to boost sales.":["\u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u0645\u0648\u0635\u0649 \u0628\u0647\u0627 \u0647\u064a \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u0623\u0643\u062b\u0631 \u0631\u0628\u062d\u064a\u0629 \u0623\u0648 \u0630\u0627\u062a \u0627\u0644\u062c\u0648\u062f\u0629 \u0627\u0644\u0623\u0641\u0636\u0644 \u0623\u0648 \u0627\u0644\u0623\u0643\u062b\u0631 \u062a\u0643\u0644\u0641\u0629 \u0639\u0627\u062f\u0629. \u062c\u0631\u0651\u0650\u0628 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0644\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a."],"What did you try to build using this block? What did and didn't work?":["\u0645\u0627 \u0627\u0644\u0630\u064a \u062c\u0631\u0651\u064e\u0628\u062a \u0625\u0646\u0634\u0627\u0621\u0647 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0647\u0630\u0627 \u0627\u0644\u0645\u0643\u0648\u0651\u0650\u0646\u061f \u0645\u0627 \u0627\u0644\u0630\u064a \u0646\u062c\u062d\u060c \u0648\u0645\u0627 \u0627\u0644\u0630\u064a \u0644\u0645 \u064a\u0646\u062c\u062d\u061f"],"What products do you want to show?":["\u0645\u0627 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0631\u064a\u062f \u0639\u0631\u0636\u0647\u0627\u061f"],"Width":["\u0627\u0644\u0639\u0631\u0636"],"You may also like":["\u0642\u062f \u064a\u0639\u062c\u0628\u0643 \u0643\u0630\u0644\u0643"],"You may be interested in\u2026":["\u0642\u062f \u062a\u0643\u0648\u0646 \u0645\u0647\u062a\u0645\u064b\u0627 \u0628\u0640..."],"Your store doesn't have any product attributes.":["\u0644\u0627 \u064a\u062d\u062a\u0648\u064a \u0645\u062a\u062c\u0631\u0643 \u0639\u0644\u0649 \u0623\u064a \u0633\u0645\u0627\u062a \u0644\u0644\u0645\u0646\u062a\u062c\u0627\u062a."],"Your store doesn't have any products.":["\u0644\u0627 \u064a\u062d\u062a\u0648\u064a \u0645\u062a\u062c\u0631\u0643 \u0639\u0644\u0649 \u0623\u064a \u0645\u0646\u062a\u062c\u0627\u062a."],"Z \u2192 A":["\u064a \u2190 \u0623"],"\ud83d\ude4f\ud83c\udffb Thanks for sharing \u2014 we're on it!":["\ud83d\ude4f\ud83c\udffb \u0634\u0643\u0631\u064b\u0627 \u0644\u0644\u0645\u0634\u0627\u0631\u0643\u0629 - \u0633\u0646\u062a\u0648\u0644\u0649 \u0627\u0644\u0623\u0645\u0631!"]}}}