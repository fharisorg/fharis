{"translation-revision-date":"2025-08-08 00:07+0000","generator":"Loco https:\/\/localise.biz\/","source":"assets\/client\/blocks\/mini-cart.js","domain":"woocommerce","locale_data":{"woocommerce":{"":{"domain":"","lang":"ar","plural-forms":"nplurals=6; plural=n==0 ? 0 : n==1 ? 1 : n==2 ? 2 : n%100>=3 && n%100<=10 ? 3 : n%100>=11 ? 4 : 5;"},"Always (even if empty)":["\u062f\u0627\u0626\u0645\u064b\u0627 (\u062d\u062a\u0649 \u0641\u064a \u062d\u0627\u0644 \u0643\u0627\u0646\u062a \u0641\u0627\u0631\u063a\u0629)"],"Behavior":["\u0633\u0644\u0648\u0643"],"Cart Drawer":["\u062f\u0631\u062c \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642"],"Cart Icon":["\u0623\u064a\u0642\u0648\u0646\u0629 \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642"],"Display":["\u0627\u0644\u0639\u0631\u0636"],"Display total price":["\u0639\u0631\u0636 \u0627\u0644\u0633\u0639\u0631 \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a"],"Edit Mini-Cart Drawer template":["\u062a\u062d\u0631\u064a\u0631 \u0642\u0627\u0644\u0628 \u062f\u0631\u062c \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u0635\u063a\u064a\u0631\u0629"],"Hide":["\u0625\u062e\u0641\u0627\u0621"],"Icon":["\u0623\u064a\u0642\u0648\u0646\u0629"],"Mini-Cart in cart and checkout pages":["\u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0641\u064a \u0635\u0641\u062d\u062a\u064e\u064a \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0648\u0627\u0644\u0633\u062f\u0627\u062f"],"Navigate to checkout when clicking the Mini-Cart, instead of opening the drawer.":["\u0627\u0646\u062a\u0642\u0644 \u0625\u0644\u0649 \u0627\u0644\u0633\u062f\u0627\u062f \u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u0635\u063a\u064a\u0631\u0629\u060c \u0628\u062f\u0644\u0627\u064b \u0645\u0646 \u0641\u062a\u062d \u0623\u062f\u0627\u0629 \u0627\u0644\u0633\u062d\u0628."],"Never":["\u0623\u0628\u062f\u064b\u0627"],"Only if cart has items":["\u0641\u0642\u0637 \u0641\u064a \u062d\u0627\u0644 \u0643\u0627\u0646\u062a \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0639\u0646\u0627\u0635\u0631"],"Open drawer when adding":["\u0641\u062a\u062d \u062f\u0631\u062c \u0639\u0646\u062f \u0627\u0644\u0625\u0636\u0627\u0641\u0629"],"Price":["\u0627\u0644\u0633\u0639\u0631"],"Product Count":["\u0639\u062f\u062f \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a"],"Remove":["\u0625\u0632\u0627\u0644\u0629"],"Select how the Mini-Cart behaves in the Cart and Checkout pages. This might affect the header layout.":["\u062d\u062f\u062f \u0627\u0644\u0643\u064a\u0641\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u062a\u0635\u0631\u0641 \u0628\u0647\u0627 \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0641\u064a \u0635\u0641\u062d\u062a\u064a \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0648\u0627\u0644\u0633\u062f\u0627\u062f. \u0642\u062f \u064a\u0624\u062b\u0631 \u0630\u0644\u0643 \u0641\u064a \u062a\u062e\u0637\u064a\u0637 \u0627\u0644\u062a\u0631\u0648\u064a\u0633\u0629."],"Settings":["\u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a"],"Show Cart Item Count:":["\u0625\u0638\u0647\u0627\u0631 \u0639\u062f\u062f \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0641\u064a \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642:"],"The editor does not display the real count value, but a placeholder to indicate how it will look on the front-end.":["\u0644\u0627 \u064a\u0639\u0631\u0636 \u0627\u0644\u0645\u062d\u0631\u0631 \u0642\u064a\u0645\u0629 \u0627\u0644\u0639\u062f\u062f \u0627\u0644\u062d\u0642\u064a\u0642\u064a\u0629\u060c \u0644\u0643\u0646\u0647 \u064a\u0639\u0631\u0636 \u0639\u0646\u0635\u0631\u064b\u0627 \u0646\u0627\u0626\u0628\u064b\u0627 \u0644\u0644\u0625\u0634\u0627\u0631\u0629 \u0625\u0644\u0649 \u0627\u0644\u0643\u064a\u0641\u064a\u0629 \u0627\u0644\u062a\u064a \u0633\u064a\u0628\u062f\u0648 \u0628\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0623\u0645\u0627\u0645\u064a\u0629."],"Toggle to disable opening the Mini-Cart drawer when clicking the cart icon, and instead navigate to the checkout page.":["\u0642\u0645 \u0628\u0627\u0644\u062a\u0628\u062f\u064a\u0644 \u0644\u062a\u0639\u0637\u064a\u0644 \u0641\u062a\u062d \u0623\u062f\u0627\u0629 \u0627\u0644\u0633\u062d\u0628 \u0645\u0646 \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0623\u064a\u0642\u0648\u0646\u0629 \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642\u060c \u0648\u0627\u0646\u062a\u0642\u0644 \u0625\u0644\u0649 \u0635\u0641\u062d\u0629 \u0627\u0644\u0633\u062f\u0627\u062f \u0628\u062f\u0644\u0627\u064b \u0645\u0646 \u0630\u0644\u0643."],"Toggle to display the total price of products in the shopping cart. If no products have been added, the price will not display.":["\u0642\u0645 \u0628\u0627\u0644\u062a\u0628\u062f\u064a\u0644 \u0644\u0639\u0631\u0636 \u0625\u062c\u0645\u0627\u0644\u064a \u0633\u0639\u0631 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0641\u064a \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642. \u0641\u064a \u062d\u0627\u0644 \u0639\u062f\u0645 \u0625\u0636\u0627\u0641\u0629 \u0623\u064a \u0645\u0646\u062a\u062c\u0627\u062a\u060c \u0641\u0644\u0646 \u064a\u064f\u0639\u0631\u0636 \u0627\u0644\u0633\u0639\u0631."],"Toggle to open the Mini-Cart drawer when a shopper adds a product to their cart.":["\u0642\u0645 \u0628\u0627\u0644\u062a\u0628\u062f\u064a\u0644 \u0644\u0641\u062a\u062d \u062f\u0631\u062c \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0639\u0646\u062f\u0645\u0627 \u064a\u0636\u064a\u0641 \u0627\u0644\u0645\u062a\u0633\u0648\u0642 \u0645\u0646\u062a\u062c\u064b\u0627 \u0625\u0644\u0649 \u0639\u0631\u0628\u0629 \u0627\u0644\u062a\u0633\u0648\u0642 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0647."],"When opened, the Mini-Cart drawer gives shoppers quick access to view their selected products and checkout.":["\u0639\u0646\u062f \u0641\u062a\u062d\u0647\u060c \u064a\u0645\u0646\u062d \u062f\u0631\u062c Mini-Cart \u0644\u0644\u0645\u062a\u0633\u0648\u0642\u064a\u0646 \u0625\u0645\u0643\u0627\u0646\u064a\u0629 \u0627\u0644\u0648\u0635\u0648\u0644 \u0627\u0644\u0633\u0631\u064a\u0639 \u0644\u0639\u0631\u0636 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u062a\u064a \u0627\u062e\u062a\u0627\u0631\u0648\u0647\u0627 \u0648\u0625\u062a\u0645\u0627\u0645 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0634\u0631\u0627\u0621."]}}}